using "2026"
;; eic — Advanced Process Isolation Sandbox for HackerOS
;; Isolation Cell for pentesting and malware analysis
;; Usage: eic [--net=isolated] [--trace] [--output=log.txt] --run <binary>

fn get_home() -> string is
    return trim(shell("echo $HOME"))
end

fn eic_version() -> string is
    return "eic v0.1.0 — HackerOS Isolation Cell"
end

fn print_banner() is
    write(cyan_text("╔══════════════════════════════════════════════════════╗"))
    write(cyan_text("║") + bold("  eic — HackerOS Isolation Cell v0.1.0              ") + cyan_text("║"))
    write(cyan_text("║") + "  Advanced process sandbox for pentest + malware      " + cyan_text("║"))
    write(cyan_text("╚══════════════════════════════════════════════════════╝"))
    write("")
end

fn print_help() is
    print_banner()
    write(bold("USAGE:"))
    write("  eic --run <binary>                   Full isolation (no net, CoW fs)")
    write("  eic --net=isolated --run <binary>    Isolated network (no LAN access)")
    write("  eic --trace --output=log.txt <bin>   Syscall + file + IP trace log")
    write("  eic --emit-ir --run <binary>         Show IR (sandbox plan) and exit")
    write("")
    write(bold("FLAGS:"))
    write("  --run <binary>       Target to execute inside sandbox")
    write("  --net=none           No network (default)")
    write("  --net=isolated       Internal NATd interface only — no LAN")
    write("  --trace              Record all syscalls, file accesses, IP connections")
    write("  --output=<file>      Write trace log to file (default: eic_trace.log)")
    write("  --timeout=<sec>      Kill sandboxed process after N seconds")
    write("  --allow-read=<path>  Whitelist a real path for read-only access")
    write("  --emit-ir            Print sandbox plan and exit")
    write("  --version            Print version")
    write("  --help               Show this help")
    write("")
    write(bold("EXAMPLES:"))
    write("  eic --run ./unknown_exploit.bin")
    write("  eic --net=isolated --run ./web_scanner.h#")
    write("  eic --trace --output=malware.log --run ./suspicious.elf")
end

fn check_deps() -> bool is
    let ok: bool = true
    let deps: string = "unshare bwrap strace ip"
    let check: string = trim(shell("for d in " + deps + "; do command -v $d >/dev/null 2>&1 || echo missing:$d; done"))
    if check != "" is
        write(yellow_text("warn:") + " missing tools: " + check)
        write(dim_text("  install: sudo apt install util-linux bubblewrap strace iproute2"))
        ok = false
    end
    return ok
end

fn setup_cow_rootfs(session_dir: string) -> string is
    ;; Create an overlay (CoW) tmpfs rootdir inside the session
    let overlay_dir: string = session_dir + "/overlay"
    let upper_dir:   string = session_dir + "/upper"
    let work_dir:    string = session_dir + "/work"
    let merged_dir:  string = session_dir + "/merged"
    shell("mkdir -p " + overlay_dir + " " + upper_dir + " " + work_dir + " " + merged_dir)
    ;; Try overlayfs (needs root or user ns) — fall back to tmpfs copy
    let result: string = trim(shell(
        "mount -t overlay overlay -o lowerdir=/,upperdir=" + upper_dir +
        ",workdir=" + work_dir + " " + merged_dir + " 2>&1"))
    if contains(result, "permission denied") is
        ;; Unprivileged fallback: bwrap will handle the overlay
        write(dim_text("  note: using bwrap bind-mount mode (no root overlay)"))
        shell("cp -a /etc/passwd /etc/group /etc/hostname " + overlay_dir + " 2>/dev/null")
        return session_dir
    end
    return merged_dir
end

