;; JSON output
;; ═══════════════════════════════════════════════════════════════════════════════

fn print_json(r: ScanReport) is
    write("")
    write("  \x1b[2m── JSON ──────────────────────────────────────────\x1b[0m")
    write("  {")
    write("    \"module\":   \"" + r.module + "\",")
    write("    \"target\":   \"" + r.target + "\",")
    write("    \"findings\": " + to_string(r.findings) + ",")
    write("    \"risk\":     " + to_string(r.risk) + ",")
    write("    \"results\":  " + r.json)
    write("  }")
end

;; ═══════════════════════════════════════════════════════════════════════════════
;; Prosty parser argumentów CLI
;; ═══════════════════════════════════════════════════════════════════════════════

fn arg_get(args: [string], argc: int, key: string) -> string is
    ;; Szuka "--key=value" lub "--key value" w args
    let prefix: string = "--" + key + "="
    let mut i: int = 0
    while i < argc is
        if string_starts_with(args[i], prefix) is
            return string_slice(args[i], string_len(prefix), string_len(args[i]))
        end
        if args[i] == "--" + key && i + 1 < argc is
            return args[i + 1]
        end
        i += 1
    end
    return ""
end

fn arg_flag(args: [string], argc: int, key: string) -> bool is
    let mut i: int = 0
    while i < argc is
        if args[i] == "--" + key is return true end
        i += 1
    end
    return false
end

;; ═══════════════════════════════════════════════════════════════════════════════
;; MAIN
;; ═══════════════════════════════════════════════════════════════════════════════

fn main() is
    banner()

    let args:  [string] = env::args()
    let argc:  int      = array_len(args)

    ;; Bez argumentów → tryb demo
    if argc <= 1 is
        write("  \x1b[2m[demo — uruchom z --module=scada/iot/web3]\x1b[0m")
        write("")

        write("  \x1b[1m══ Demo SCADA ══\x1b[0m")
        let s: ScanReport = run_scada("192.168.100.50", false)
        print_json(s)

        write("")
        write("  \x1b[1m══ Demo IoT ══\x1b[0m")
        let io: ScanReport = run_iot("192.168.1.100", true)
        print_json(io)

        write("")
        write("  \x1b[1m══ Demo Web3 ══\x1b[0m")
        let w: ScanReport = run_web3("./demo_contract.hex")
        print_json(w)

        write("")
        usage()
        return
    end

    let module:     string = arg_get(args, argc, "module")
    let target:     string = arg_get(args, argc, "target")
    let source:     string = arg_get(args, argc, "source")
    let aggressive: bool   = arg_flag(args, argc, "aggressive")
    let all_ports:  bool   = arg_get(args, argc, "ports") == "all"
    let json_out:   bool   = arg_flag(args, argc, "json")

    if module == "" is
        write("  \x1b[31merror:\x1b[0m --module wymagany")
        write("")
        usage()
        exit(1)
        return
    end

    let report: ScanReport = match module is
        "scada" => is
            if target == "" is
                write("  \x1b[31merror:\x1b[0m --target wymagany dla modułu scada")
                exit(1)
            end
            run_scada(target, all_ports)
        end
        "iot"   => is
            if target == "" is
                write("  \x1b[31merror:\x1b[0m --target wymagany dla modułu iot")
                exit(1)
            end
            run_iot(target, aggressive)
        end
        "web3"  => is
            let src: string = if source != "" then source else "./contract.hex" end
            run_web3(src)
        end
        _ => is
            write("  \x1b[31merror:\x1b[0m nieznany moduł '" + module + "'")
            write("")
            usage()
            exit(1)
            return ScanReport {
                module: "", target: "", findings: 0, risk: 0, json: "[]"
            }
        end
    end

    if json_out is
        print_json(report)
    end
end
