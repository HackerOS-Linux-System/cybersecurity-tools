;; MODULE: IoT
;; ═══════════════════════════════════════════════════════════════════════════════

struct IoTResult is
    pub ip:        string
    pub telnet:    bool
    pub ssh:       bool
    pub http:      bool
    pub upnp:      bool
    pub mdns:      bool
    pub open_ports: string
    pub cves:      string
    pub risk:      string
end

fn iot_classify(telnet: bool, upnp: bool, open: int) -> string is
    if telnet is return "CRITICAL" end
    if upnp   is return "HIGH"    end
    if open > 5 is return "MEDIUM" end
    return "LOW"
end

fn iot_scan_host(ip: string, aggressive: bool) -> IoTResult is
    let mut ports: string = ""
    let mut count: int    = 0
    let mut cves:  string = ""

    ;; Telnet — zawsze sprawdzamy (CRITICAL)
    let tel_banner: string = net::tcp_banner(ip, 23, 1500)
    let has_telnet: bool   = string_len(tel_banner) > 0
    if has_telnet is
        count += 1
        ports  = ports + "23/tcp(Telnet!) "
        cves   = cves  + "CVE-2017-7577 "
    end

    ;; SSH
    let ssh_banner: string = net::tcp_banner(ip, 22, 1500)
    let has_ssh:    bool   = string_len(ssh_banner) > 0
    if has_ssh is
        count += 1
        ports  = ports + "22/tcp(SSH) "
        ;; Sprawdź słaby banner (OpenSSH < 7)
        if string_contains(ssh_banner, "OpenSSH_6") ||
           string_contains(ssh_banner, "OpenSSH_5") is
            cves = cves + "CVE-2016-6515 "
        end
    end

    ;; HTTP
    let http_banner: string = net::tcp_banner(ip, 80, 1500)
    let has_http:    bool   = string_len(http_banner) > 0
    if has_http is
        count += 1
        ports  = ports + "80/tcp(HTTP) "
        ;; Szukaj paneli admina urządzeń IoT
        if string_contains(http_banner, "mini_httpd") ||
           string_contains(http_banner, "GoAhead")    ||
           string_contains(http_banner, "Boa/0") is
            cves = cves + "CVE-2019-9670 "
        end
    end

    ;; UPnP
    let has_upnp: bool = proto::upnp_scan(ip)
    if has_upnp is
        cves = cves + "CVE-2020-12695 "
    end

    ;; mDNS (tylko aggressive)
    let has_mdns: bool = if aggressive then proto::mdns_probe(ip) else false end

    ;; RTSP (kamery IP) — tylko aggressive
    if aggressive is
        let rtsp_banner: string = net::tcp_banner(ip, 554, 1000)
        if string_len(rtsp_banner) > 0 is
            count += 1
            ports  = ports + "554/tcp(RTSP) "
            cves   = cves  + "CVE-2018-10088 "
        end

        ;; MQTT
        let mqtt_banner: string = net::tcp_banner(ip, 1883, 1000)
        if string_len(mqtt_banner) > 0 is
            count += 1
            ports  = ports + "1883/tcp(MQTT) "
        end
    end

    let risk: string = iot_classify(has_telnet, has_upnp, count)

    return IoTResult {
        ip:         ip,
        telnet:     has_telnet,
        ssh:        has_ssh,
        http:       has_http,
        upnp:       has_upnp,
        mdns:       has_mdns,
        open_ports: ports,
        cves:       cves,
        risk:       risk,
    }
end

fn run_iot(target: string, aggressive: bool) -> ScanReport is
    write("  \x1b[1;35m[IoT]\x1b[0m " + target)
    if aggressive is
        write("  \x1b[2mTryb: aggressive — rozszerzony zakres portów\x1b[0m")
    end
    write("")

    let res: IoTResult = iot_scan_host(target, aggressive)
    let mut findings:  int = 0

    if res.telnet is
        findings += 1
        write("  \x1b[1;31m[CRITICAL]\x1b[0m Telnet otwarty — " + target + ":23")
        write("             Cleartext credentials! Natychmiastowa naprawa wymagana.")
        write("")
    end

    if res.upnp is
        findings += 1
        write("  \x1b[31m[HIGH]\x1b[0m     UPnP wykryty — port 1900/udp")
        write("             Możliwe przekierowanie portów przez atakującego.")
        write("")
    end

    if res.http is
        findings += 1
        write("  \x1b[33m[MEDIUM]\x1b[0m   Panel HTTP — " + target + ":80")
        write("             Sprawdź domyślne hasła i wersję firmware.")
        write("")
    end

    if res.ssh is
        write("  \x1b[2m[INFO]\x1b[0m     SSH — " + target + ":22")
        if string_contains(res.cves, "CVE-2016-6515") is
            write("             \x1b[33m⚠\x1b[0m Słaba wersja OpenSSH — zaktualizuj")
        end
        write("")
    end

    if res.open_ports != "" is
        write("  Otwarte porty : " + res.open_ports)
    end
    if res.cves != "" is
        write("  CVE           : \x1b[33m" + res.cves + "\x1b[0m")
    end
    write("  Ryzyko        : " + col_risk(res.risk))
    write("")

    let risk_n: int = severity_score(res.risk)

    let json: string = "[{\"ip\":\"" + target +
        "\",\"risk\":\"" + res.risk +
        "\",\"telnet\":" + if res.telnet then "true" else "false" end +
        ",\"upnp\":"    + if res.upnp   then "true" else "false" end +
        ",\"cves\":\""  + res.cves + "\"}]"

    write("\x1b[2m──────────────────────────────────────────────────\x1b[0m")
    write("  Znalezisk: " + to_string(findings) + "  |  ryzyko: " + to_string(risk_n) + "/100")
    write("")

    return ScanReport {
        module:   "iot",
        target:   target,
        findings: findings,
        risk:     risk_n,
        json:     json,
    }
end

