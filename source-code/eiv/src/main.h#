;; MODULE: Web3
;; ═══════════════════════════════════════════════════════════════════════════════

fn read_hex_file(path: string) -> bytes is
    ;; io::read_bytes(path) gdy io module dostępny
    ;; Na razie zwracamy przykładowy bytecode EVM do demonstracji
    unsafe arena(64) is
        ;; Przykładowy bytecode z: PUSH1 0x00, CALL, SSTORE, SELFDESTRUCT
        let demo: bytes = b"\x60\x00\xF1\x55\xFF\x01\x01\x57\x32\x14\x57"
        return demo
    end
end

fn run_web3(source: string) -> ScanReport is
    write("  \x1b[1;33m[Web3]\x1b[0m " + source)
    write("  \x1b[2mAnaliza statyczna bytecode EVM — wzorce podatności\x1b[0m")
    write("")

    let bytecode: bytes  = read_hex_file(source)
    let blen:     int    = bytes_len(bytecode)
    write("  Bytecode  : " + to_string(blen) + " bajtów")
    write("  Analiza   : Reentrancy · SELFDESTRUCT · tx.origin · overflow")
    write("")

    let findings: [proto::Web3Finding] = proto::analyze_bytecode(bytecode, blen)
    let count:    int = array_len(findings)

    let mut json:     string = "["
    let mut risk_sum: int    = 0
    let mut i:        int    = 0

    while i < count is
        let f: proto::Web3Finding = findings[i]
        let sep: string = if i > 0 then "," else "" end

        write("  " + col_risk(f.severity) + "  " + f.vuln +
              "  @ " + fmt_offset(f.offset))
        write("    Fix: " + f.fix)
        write("")

        risk_sum += severity_score(f.severity)
        json = json + sep +
               "{\"vuln\":\"" + f.vuln +
               "\",\"severity\":\"" + f.severity +
               "\",\"offset\":" + to_string(f.offset) + "}"
        i += 1
    end

    json = json + "]"

    let final_risk: int = if count > 0 then risk_sum / count else 0 end

    write("\x1b[2m──────────────────────────────────────────────────\x1b[0m")
    write("  Podatności: " + to_string(count) + "  |  ryzyko: " + to_string(final_risk) + "/100")
    write("")

    return ScanReport {
        module:   "web3",
        target:   source,
        findings: count,
        risk:     final_risk,
        json:     json,
    }
end

