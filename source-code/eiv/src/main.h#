struct ScanReport is
    pub module:   string
    pub target:   string
    pub findings: int
    pub risk:     int       ;; 0-100
    pub json:     string
end

;; ═══════════════════════════════════════════════════════════════════════════════
;; Narzędzia wyświetlania
;; ═══════════════════════════════════════════════════════════════════════════════

fn banner() is
    write("")
    write("  \x1b[1;32m┌─────────────────────────────────────────────────┐\x1b[0m")
    write("  \x1b[1;32m│\x1b[0m  \x1b[1;37meiv\x1b[0m  specialized recon scanner  \x1b[1;32mv0.8\x1b[0m          \x1b[1;32m│\x1b[0m")
    write("  \x1b[1;32m│\x1b[0m  \x1b[2mSCADA · IoT · Web3  —  100% H#\x1b[0m                \x1b[1;32m│\x1b[0m")
    write("  \x1b[1;32m└─────────────────────────────────────────────────┘\x1b[0m")
    write("")
end

fn col_risk(risk: string) -> string is
    if risk == "CRITICAL" is return "\x1b[1;31m" + risk + "\x1b[0m" end
    if risk == "HIGH"     is return "\x1b[31m"   + risk + "\x1b[0m" end
    if risk == "MEDIUM"   is return "\x1b[33m"   + risk + "\x1b[0m" end
    if risk == "LOW"      is return "\x1b[32m"   + risk + "\x1b[0m" end
    return risk
end

fn severity_score(s: string) -> int is
    if s == "CRITICAL" is return 95 end
    if s == "HIGH"     is return 75 end
    if s == "MEDIUM"   is return 50 end
    if s == "LOW"      is return 25 end
    return 0
end

fn fmt_offset(off: int) -> string is
    ;; prosty hex bez std::fmt
    return "0x" + to_hex(off)
end

fn usage() is
    write("  \x1b[1mUżycie:\x1b[0m  eiv --module=<mod> [opcje]")
    write("")
    write("  \x1b[1mModuły:\x1b[0m")
    write("    \x1b[36mscada\x1b[0m  --target=<ip|cidr>  [--ports=default|all]")
    write("    \x1b[35miot\x1b[0m    --target=<ip>  [--aggressive]")
    write("    \x1b[33mweb3\x1b[0m   --source=<plik.hex>")
    write("")
    write("  \x1b[1mPrzykłady:\x1b[0m")
    write("    eiv --module=scada  --target=10.0.0.0/24")
    write("    eiv --module=iot    --target=192.168.1.50 --aggressive")
    write("    eiv --module=web3   --source=./contract.hex")
    write("")
end

;; ═══════════════════════════════════════════════════════════════════════════════
;; MODULE: SCADA
;; ═══════════════════════════════════════════════════════════════════════════════

fn scada_risk_label(res: proto::ModbusResult) -> string is
    if !res.found is return "NONE" end
    return res.risk
end

fn run_scada(target: string, all_ports: bool) -> ScanReport is
    write("  \x1b[1;36m[SCADA]\x1b[0m " + target)
    write("  \x1b[2mProtokoly: Modbus/502 · BACnet/47808 · EtherNet\\/IP/44818 · Profinet/34964\x1b[0m")
    write("")

    let mut findings: int    = 0
    let mut risk_sum: int    = 0
    let mut json:     string = "["

    ;; ── Modbus TCP ──
    write("  \x1b[2mskanuję Modbus TCP...\x1b[0m")
    let mb: proto::ModbusResult = proto::modbus_scan(target)
    if mb.found is
        findings += 1
        risk_sum += severity_score(mb.risk)
        write("  \x1b[32m✓\x1b[0m  \x1b[1mModbus TCP\x1b[0m  " + target + ":502")
        write("        coile   : " + to_string(mb.coil_count))
        write("        firmware: " + mb.firmware)
        write("        ryzyko  : " + col_risk(mb.risk))
        if mb.coil_count > 100 is
            write("        \x1b[33m⚠\x1b[0m  dużo coili — sprawdź autoryzację")
        end
        write("")
        json = json + "{\"proto\":\"Modbus\",\"ip\":\"" + target +
               "\",\"coils\":" + to_string(mb.coil_count) +
               ",\"risk\":\"" + mb.risk + "\"}"
    else is
        write("  \x1b[2m─\x1b[0m  Modbus TCP      brak odpowiedzi")
    end

    ;; ── BACnet ──
    write("  \x1b[2mskanuję BACnet/IP...\x1b[0m")
    let bac: bool = proto::bacnet_scan(target)
    if bac is
        findings += 1
        risk_sum += 65
        let sep: string = if findings > 1 then "," else "" end
        write("  \x1b[32m✓\x1b[0m  \x1b[1mBACnet/IP\x1b[0m   " + target + ":47808")
        write("        ryzyko  : " + col_risk("HIGH"))
        write("        uwaga   : brak natywnego szyfrowania w BACnet")
        write("")
        json = json + sep + "{\"proto\":\"BACnet\",\"ip\":\"" + target + "\",\"risk\":\"HIGH\"}"
    else is
        write("  \x1b[2m─\x1b[0m  BACnet/IP       brak odpowiedzi")
    end

    ;; ── EtherNet/IP ──
    write("  \x1b[2mskanuję EtherNet/IP...\x1b[0m")
    let eip: bool = proto::ethernetip_scan(target)
    if eip is
        findings += 1
        risk_sum += 55
        let sep: string = if findings > 1 then "," else "" end
        write("  \x1b[32m✓\x1b[0m  \x1b[1mEtherNet/IP\x1b[0m " + target + ":44818")
        write("        ryzyko  : " + col_risk("MEDIUM"))
        write("")
        json = json + sep + "{\"proto\":\"EtherNetIP\",\"ip\":\"" + target + "\",\"risk\":\"MEDIUM\"}"
    else is
        write("  \x1b[2m─\x1b[0m  EtherNet/IP     brak odpowiedzi")
    end

    ;; ── Profinet ──
    if all_ports is
        write("  \x1b[2mskanuję Profinet...\x1b[0m")
        let pn: bool = proto::profinet_scan(target)
        if pn is
            findings += 1
            risk_sum += 50
            let sep: string = if findings > 1 then "," else "" end
            write("  \x1b[32m✓\x1b[0m  \x1b[1mProfinet\x1b[0m    " + target + ":34964")
            write("        ryzyko  : " + col_risk("MEDIUM"))
            write("")
            json = json + sep + "{\"proto\":\"Profinet\",\"ip\":\"" + target + "\",\"risk\":\"MEDIUM\"}"
        else is
            write("  \x1b[2m─\x1b[0m  Profinet        brak odpowiedzi")
        end
    end

    json = json + "]"

    let final_risk: int = if findings > 0 then risk_sum / findings else 0 end

    write("")
    write("  \x1b[2m──────────────────────────────────────────────────\x1b[0m")
    write("  Urządzeń: " + to_string(findings) + "  |  ryzyko: " + to_string(final_risk) + "/100")
    write("")

    return ScanReport {
        module:   "scada",
        target:   target,
        findings: findings,
        risk:     final_risk,
        json:     json,
    }
end

