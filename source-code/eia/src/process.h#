use "std -> fs"   from "fs"
use "std -> str"  from "str"

;; ── Result struct ─────────────────────────────────────────────────────────────

pub struct ToolResult is
    pub status:   string   ;; "ok", "timeout", "error", "not_found"
    pub stdout:   string   ;; Full captured standard output
    pub stderr:   string   ;; Full captured standard error
    pub exit_code: int
    pub duration_ms: int
end

;; ── Tool definitions ──────────────────────────────────────────────────────────
;; Each entry maps an eia tool name to an actual command template.
;; {TARGET} is substituted at runtime.

fn tool_command(tool: string, target: string) -> string is
    match tool is
        "nmap"    => return "nmap -sV -sC -oX /tmp/eia_nmap_out.xml " + target
        "nmap-full" => return "nmap -A -p- -oX /tmp/eia_nmap_full_out.xml " + target
        "nmap-udp"  => return "nmap -sU --top-ports 200 -oX /tmp/eia_nmap_udp_out.xml " + target
        "eiv"     => return "eiv --target " + target + " --output /tmp/eia_eiv_out.json --format json"
        "jam"     => return "jam --url " + target + " --output /tmp/eia_jam_out.json --format json"
        "burp"    => return "burp-rest --target " + target + " --export /tmp/eia_burp_out.xml"
        "ping"    => return "ping -c 1 -W 2 " + target
        "traceroute" => return "traceroute -n " + target
        _         => return ""
    end
end

fn tool_output_file(tool: string) -> string is
    match tool is
        "nmap"    => return "/tmp/eia_nmap_out.xml"
        "nmap-full" => return "/tmp/eia_nmap_full_out.xml"
        "nmap-udp"  => return "/tmp/eia_nmap_udp_out.xml"
        "eiv"     => return "/tmp/eia_eiv_out.json"
        "jam"     => return "/tmp/eia_jam_out.json"
        "burp"    => return "/tmp/eia_burp_out.xml"
        _         => return ""
    end
end

;; ── Main subprocess runner ────────────────────────────────────────────────────
;;
;; On HackerOS (compiled), this is a native syscall-based subprocess with
;; true async I/O and timeout enforcement through the eix sandbox. In
;; interpreter mode (eia preview), we call the underlying tools via the
;; process:: stdlib and stream their output synchronously.

pub fn run_tool(tool: string, target: string, timeout_sec: int) -> ToolResult is
    let cmd = tool_command(tool, target)
    if cmd == "" is
        write("[process] unknown tool: " + tool)
        return ToolResult {
            status:   "not_found",
            stdout:   "",
            stderr:   "no command template for: " + tool,
            exit_code: 127,
            duration_ms: 0,
        }
    end

    write("[process] exec: " + cmd)
    write("[process] timeout: " + conv::int_to_str(timeout_sec) + "s")

    ;; In interpreter mode: run via shell and capture output.
    ;; In compiled mode: this maps to the eix sandbox process manager.
    let result = proc::run_cmd(cmd, timeout_sec)

    if result.timed_out is
        write("[process] TIMEOUT after " + conv::int_to_str(timeout_sec) + "s")
        ;; Still try to read whatever was written to the output file
        let partial = read_tool_output(tool)
        return ToolResult {
            status:      "timeout",
            stdout:      partial,
            stderr:      "process timed out",
            exit_code:   -1,
            duration_ms: timeout_sec * 1000,
        }
    end

    if result.exit_code != 0 is
        write("[process] tool exited with code " + conv::int_to_str(result.exit_code))
    end

    ;; Prefer reading from the tool's output file (structured format) over
    ;; raw stdout, which is often progress/status noise.
    let output_file = tool_output_file(tool)
    let file_out = read_tool_output(tool)
    let stdout = if file_out != "" is file_out else result.stdout end

    return ToolResult {
        status:      if result.exit_code == 0 is "ok" else "error" end,
        stdout:      stdout,
        stderr:      result.stderr,
        exit_code:   result.exit_code,
        duration_ms: result.duration_ms,
    }
end

fn read_tool_output(tool: string) -> string is
    let path = tool_output_file(tool)
    if path == "" is return "" end
    if !fs::exists(path) is return "" end
    return fs::read(path)
end

;; ── Live stream reader ────────────────────────────────────────────────────────
;; Reads from a subprocess's stdout pipe line-by-line, emitting each line
;; as it arrives rather than buffering until the process exits. Used for
;; long-running tools (full nmap scans, etc.) to give live progress output.

pub fn stream_tool(tool: string, target: string, timeout_sec: int) is
    let cmd = tool_command(tool, target)
    if cmd == "" is
        write("[stream] unknown tool: " + tool)
        return
    end

    write("[stream] starting: " + cmd)
    let pipe = proc::open_pipe(cmd, timeout_sec)

    while proc::pipe_has_data(pipe) is
        let line = proc::pipe_read_line(pipe)
        if line != "" is
            write("[" + tool + "] " + line)
        end
    end

    proc::pipe_close(pipe)
    write("[stream] " + tool + " finished")
end

;; ── Sandbox helpers (eix integration) ────────────────────────────────────────
;; eix is HackerOS's process isolation layer — runs subprocesses in a
;; restricted namespace with no network access beyond the target range,
;; no filesystem writes outside /tmp/eia_*, and CPU/memory limits.
;;
;; These functions are no-ops in interpreter preview mode; the real
;; implementation is provided by the eix stdlib module in the compiled
;; H# runtime.

pub fn sandbox_check() -> bool is
    ;; Returns true if running inside an eix sandbox.
    ;; In interpreter mode, always returns false (no sandbox available).
    return proc::in_sandbox()
end

pub fn sandbox_info() -> string is
    if sandbox_check() is
        return "running inside eix sandbox (restricted)"
    else
        return "WARNING: no eix sandbox — subprocesses run with full user permissions"
    end
end

;; ── Utility ───────────────────────────────────────────────────────────────────

pub fn tool_exists(tool: string) -> bool is
    let cmd = tool_command(tool, "127.0.0.1")
    if cmd == "" is return false end

    ;; Check via `which` or `command -v`
    let result = proc::run_cmd("which " + str::split(cmd, " ")[0], 5)
    return result.exit_code == 0
end

pub fn print_tool_status() is
    let tools: [string] = ["nmap", "eiv", "jam", "burp"]
    write("Tool availability:")
    let mut i: int = 0
    while i < tools.len() is
        let t = tools[i]
        let status = if tool_exists(t) is "✓ available" else "✗ not found" end
        write("  " + t + ": " + status)
        i += 1
    end
end
